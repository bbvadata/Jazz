// This is a double inclusion! It is required for VSCode' Intellisense to work properly. This file is itself included in the
// .cpp file of the same name for unit testing. It has no effect on compilation.
#pragma once
#include "src/jazz_elements/types.h"


using namespace jazz_elements;


// Tests
// -----

SCENARIO("Testing (types) structure sizes.") {

	REQUIRE(sizeof(TensorDim)	 == 4*(MAX_TENSOR_RANK));
	REQUIRE(sizeof(ItemHeader)	 == 40);
	REQUIRE(sizeof(BlockHeader)	 == 64);
	REQUIRE(sizeof(StringBuffer) == 12);					// Empty StringBuffer == 16 bytes with min buffer size

	REQUIRE(sizeof(BlockHeader)	 == sizeof(StaticBlockHeader));

	StaticBlockHeader sbh;
	pBlockHeader p_block = (pBlockHeader) &sbh;

	REQUIRE(&p_block->cell_type		 == &sbh.cell_type);
	REQUIRE(&p_block->size			 == &sbh.size);
	REQUIRE(&p_block->created		 == &sbh.created);
	REQUIRE(&p_block->rank			 == &sbh.rank);
	REQUIRE(&p_block->range			 == &sbh.range);
	REQUIRE(&p_block->num_attributes == &sbh.num_attributes);
	REQUIRE(&p_block->total_bytes	 == &sbh.total_bytes);
	REQUIRE(&p_block->has_NA		 == &sbh.has_NA);
	REQUIRE(&p_block->hash64		 == &sbh.hash64);
	REQUIRE(&p_block->tensor		 == &sbh.tensor);

	Tensor t;

	void *p_t0 = &t;
	void *p_t1 = (void*)((uintptr_t)p_t0 + 1);
	void *p_t2 = (void*)((uintptr_t)p_t0 + 2);
	void *p_t4 = (void*)((uintptr_t)p_t0 + 4);
	void *p_t8 = (void*)((uintptr_t)p_t0 + 8);

	REQUIRE(p_t1 == &t.cell_byte[1]);
	REQUIRE(p_t1 == &t.cell_int8[1]);
	REQUIRE(p_t1 == &t.cell_bool[1]);

	REQUIRE(p_t2 == &t.cell_int16[1]);
	REQUIRE(p_t2 == &t.cell_word[1]);
	REQUIRE(p_t2 == &t.cell_float16[1]);

	REQUIRE(p_t4 == &t.cell_int[1]);
	REQUIRE(p_t4 == &t.cell_uint[1]);
	REQUIRE(p_t4 == &t.cell_single[1]);

	REQUIRE(p_t8 == &t.cell_longint[1]);
	REQUIRE(p_t8 == &t.cell_time[1]);
	REQUIRE(p_t8 == &t.cell_ulongint[1]);
	REQUIRE(p_t8 == &t.cell_double[1]);
}
