		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//qqq/ent/ky=///p//file&/tmp/new_folder;", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///o//qqq/ent/ky=///p//file&/tmp/new_folder;", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///o//qqq/ent/ky=///p//file&/tmp/new_folder;", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//base/ent/ky(//bb/ea/kk)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//base/ent/ky(//bb/ea/kk)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn//base/ent/ky(//bb/ea/kk)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn//base/ent/ky(//bb/ea/kk)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn//bash/exec/(&ls -la)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn//bash/exec/(&ls -la)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//bash/exec/(&ls -la)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=//bash/exec/(&ls -la)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//qqq/ent/ky=//base/ent/kyy[//bbb/eee/kkk]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//qqq/ent/ky=//base/ent/kyy[//bbb/eee/kkk]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///x//qqq/ent/ky=//base/ent/kyy[//bbb/eee/kkk]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//qqq/ent/ky=///x//base/ent/kyy[//bbb/eee/kkk]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=///nn2//bash/exec/qq[&[1,2]]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=///nn2//bash/exec/qq[&[1,2]]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn2//bash/exec/qq[&[1,2]]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///nn2//bash/exec/qq[&[1,2]]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//bash/exec/qq[&[1,2]]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//bash/exec/qq[&[1,2]]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=//bash/exec/qq[&[1,2]]", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=//bash/exec/qq[&[1,2]]", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//base/ent/key.raw", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=//base/ent/key.raw", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=//base/ent/key.raw", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=//base/ent/key.raw", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=///xxx//base/ent/key.text", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn//bbb/ent/ky=///xxx//base/ent/key.text", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///xxx//base/ent/key.text", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bbb/ent/ky=///xxx//base/ent/key.text", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base_s3/entity2/key4=&[[2,4], [5,6]];", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base_s3/entity2/key4=&[[2,4], [5,6]];", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_s3/entity2/key4=&[[2,4], [5,6]];", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_s3/entity2/key4=&[[2,4], [5,6]];", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn_dd//bb/entity.new", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///nn_dd//bb/entity.new", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bb/entity.new", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//bb/entity.new", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base/entity/key.attribute(123)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base/entity/key.attribute(123)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base/entity/key.attribute(123)", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base/entity/key.attribute(123)", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base/entity/key.attribute(1234)=&en-us;", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "//base/entity/key.attribute(1234)=&en-us;", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///t//base/entity/key.attribute(1234)=&en-us;", BASE_API_PUT));
		REQUIRE(hqs.state == PSTATE_FAILED);

		hqs.state = PSTATE_COMPLETE_OK;
		REQUIRE(!BAPI.parse(hqs, (pChar) "///t//base/entity/key.attribute(1234)=&en-us;", BASE_API_DELETE));
		REQUIRE(hqs.state == PSTATE_FAILED);
	}

	REQUIRE(BAPI.shut_down() == 0);
}


SCENARIO("Testing BaseAPI protected: move_const(), get_right_local(), get_right_remote(), get_left_local() and put_left_local()") {

	GIVEN("The instances are constructed, but not yet started") {
		REQUIRE(BAPI.p_channels	 == &CHN);
		REQUIRE(BAPI.p_volatile	 == &VOL);
		REQUIRE(BAPI.p_persisted == &PER);
	}

	REQUIRE(CHN.start()	== 0);
	REQUIRE(VOL.start()	== 0);
	REQUIRE(PER.start() == 0);

	REQUIRE(BAPI.start() == 0);

	GIVEN("The BaseAPI is running") {
		pChar pID = BAPI.id();
		REQUIRE(strlen(pID) > 7);
		REQUIRE(pID[0] == 'B');

		pTransaction  p_txn;
		ApiQueryState q_state;

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi.new", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl1=&[[1,0],[0,1]];", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl2=&[0,0,0,1];", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.block_from_const(p_txn, (pChar) "(echo \"2 + 2 = $(expr 2 + 2)\")", true));
		REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_TUPLE_ITEM);

		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_PUT));
		REQUIRE(BAPI.put(q_state, p_txn->p_block) == SERVICE_NO_ERROR);
		p_txn->p_owner->destroy_transaction(p_txn);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_TUPLE_ITEM);
		p_txn->p_owner->destroy_transaction(p_txn);
		REQUIRE(p_txn == nullptr);

		WHEN("We test move_const()") {
			char buff[1024] = {"What?"};
			REQUIRE(BAPI.move_const(buff, 1023, (pChar) "&this;") == RET_MV_CONST_NOTHING);
			REQUIRE(strcmp(buff, "What?") == 0);	// Doing nothing and returning ok when output is already created is expected behavior.

			THEN("We get the right return values") {
				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 1023, (pChar) "&this;") == RET_MV_CONST_NOTHING);
				REQUIRE(strcmp(buff, "this") == 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 1023, (pChar) "&this;", (pChar) "that") == RET_MV_CONST_NOTHING);
				REQUIRE(strcmp(buff, "//that/this") == 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 1023, (pChar) "this;") == RET_MV_CONST_FAILED);
				REQUIRE(buff[0]	== 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 1023, (pChar) "&this;.new") == RET_MV_CONST_NEW_ENTITY);
				REQUIRE(strcmp(buff, "this") == 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 1023, (pChar) "&this;.jew") == RET_MV_CONST_FAILED);
				REQUIRE(buff[0]	== 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 8, (pChar) "&this;", (pChar) "that") == RET_MV_CONST_FAILED);
				REQUIRE(buff[0]	== 0);

				buff[0]	= 0;
				REQUIRE(BAPI.move_const(buff, 30, (pChar) "&1234567890abcdefghij1234567890abcdef;") == RET_MV_CONST_FAILED);
				REQUIRE(buff[0]	== 0);
			}
		}

		WHEN("We test get_right_local()") {

			REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key=//r_base/r_entity/r_key(//t_base/t_entity/t_key)", BASE_API_GET));
			REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);

			THEN("We get the right return values") {
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//no_base/no_ent/key(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//lmdb/tt3bapi/bl99(//no_base/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//lmdb/tt3bapi/bl99(//lmdb/tt3bapi/bl22)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_BLOCK_NOT_FOUND);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//lmdb/tt3bapi/bl99(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//bash/exec/(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//bash/exec/(//lmdb/tt3bapi/bl3)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_NO_ERROR);
				REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_BYTE);
				REQUIRE(strcmp((char *) &p_txn->p_block->tensor.cell_byte, "2 + 2 = 4\n") == 0);
				p_txn->p_owner->destroy_transaction(p_txn);
				REQUIRE(p_txn == nullptr);

				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//bash/exec/(&echo \"2 + 2 = $(expr 2 + 2)\")", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_NO_ERROR);
				REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_BYTE);
				REQUIRE(strcmp((char *) &p_txn->p_block->tensor.cell_byte, "2 + 2 = 4\n") == 0);
				p_txn->p_owner->destroy_transaction(p_txn);
				REQUIRE(p_txn == nullptr);

				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//bash/exec/(&h23k71p39 2>/dev/null)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);

				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl9=//bash/exec/key(&aaa)", BASE_API_GET));
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);

				REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_GET));
				q_state.apply = APPLY_JAZZ_INFO;
				REQUIRE(BAPI.get_right_local(p_txn, q_state) == SERVICE_ERROR_MISC_SERVER);
			}
		}

		WHEN("We test get_right_remote()") {
			THEN("We get the right return values") {
				REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_GET));
				q_state.apply = APPLY_JAZZ_INFO;
				REQUIRE(BAPI.get_right_remote(p_txn, q_state) == SERVICE_ERROR_WRONG_ARGUMENTS);
				// Every other functionality is tested via ./test_cluster.sh
			}
		}

		WHEN("We test get_left_local()") {
			REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/entity/key", BASE_API_GET));
			REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);

			THEN("We get the right return values") {
				REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/no_ent/key(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl99(//no_base/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl99(//lmdb/tt3bapi/bl22)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_BLOCK_NOT_FOUND);
				REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl99(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);
				REQUIRE(BAPI.parse(q_state, (pChar) "//bash/exec/(//lmdb/tt3bapi/bl2)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);
				REQUIRE(BAPI.parse(q_state, (pChar) "//bash/exec/(//lmdb/tt3bapi/bl3)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_NO_ERROR);
				REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_BYTE);
				REQUIRE(strcmp((char *) &p_txn->p_block->tensor.cell_byte, "2 + 2 = 4\n") == 0);
				p_txn->p_owner->destroy_transaction(p_txn);
				REQUIRE(p_txn == nullptr);

				REQUIRE(BAPI.parse(q_state, (pChar) "//bash/exec/(&echo \"2 + 2 = $(expr 2 + 2)\")", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_NO_ERROR);
				REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_BYTE);
				REQUIRE(strcmp((char *) &p_txn->p_block->tensor.cell_byte, "2 + 2 = 4\n") == 0);
				p_txn->p_owner->destroy_transaction(p_txn);
				REQUIRE(p_txn == nullptr);

				REQUIRE(BAPI.parse(q_state, (pChar) "//bash/exec/(&h23k71p39 2>/dev/null)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);

				REQUIRE(BAPI.parse(q_state, (pChar) "//bash/exec/key(&aaa)", BASE_API_GET));
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_IO_ERROR);

				REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_GET));
				q_state.apply = APPLY_JAZZ_INFO;
				REQUIRE(BAPI.get_left_local(p_txn, q_state) == SERVICE_ERROR_MISC_SERVER);
			}
		}

		WHEN("We test put_left_local()") {
			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl2", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
			REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_INTEGER);
			THEN("We get the right return values") {
				REQUIRE(BAPI.parse(q_state, (pChar) "//kaka/tt3bapi/bl2", BASE_API_PUT));
				REQUIRE(BAPI.put_left_local(q_state, p_txn->p_block) == SERVICE_ERROR_WRONG_BASE);
			}
			p_txn->p_owner->destroy_transaction(p_txn);
		}

		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi", BASE_API_DELETE));
		REQUIRE(BAPI.remove(q_state) == SERVICE_NO_ERROR);
	}

	REQUIRE(BAPI.shut_down() == 0);

	REQUIRE(CHN.shut_down() == 0);
	REQUIRE(VOL.shut_down() == 0);
	REQUIRE(PER.shut_down() == 0);
}


SCENARIO("Testing BaseAPI: header(), get(), put(), delete()") {

	GIVEN("The instances are constructed, but not yet started") {
		REQUIRE(BAPI.p_channels	 == &CHN);
		REQUIRE(BAPI.p_volatile	 == &VOL);
		REQUIRE(BAPI.p_persisted == &PER);
	}

	REQUIRE(CHN.start()	== 0);
	REQUIRE(VOL.start()	== 0);
	REQUIRE(PER.start() == 0);

	REQUIRE(BAPI.start() == 0);

	GIVEN("The BaseAPI is running") {
		pChar pID = BAPI.id();
		REQUIRE(strlen(pID) > 7);
		REQUIRE(pID[0] == 'B');

		pTransaction  p_txn;
		ApiQueryState q_state;

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi.new", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl1=&[[1,0],[0,1]];", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl2=&[0,0,0,1];", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.block_from_const(p_txn, (pChar) "(echo \"2 + 2 = $(expr 2 + 2)\")", true));
		REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_TUPLE_ITEM);

		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_PUT));
		REQUIRE(BAPI.put(q_state, p_txn->p_block) == SERVICE_NO_ERROR);
		p_txn->p_owner->destroy_transaction(p_txn);
		REQUIRE(p_txn == nullptr);

		p_txn = (pTransaction) &q_state;
		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_GET));
		REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
		REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_TUPLE_ITEM);
		p_txn->p_owner->destroy_transaction(p_txn);
		REQUIRE(p_txn == nullptr);

		WHEN("We test header()") {
			StaticBlockHeader hea;
			REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/tt3bapi/key.attribute(1)", BASE_API_GET));
			REQUIRE(BAPI.header(hea, q_state) == SERVICE_ERROR_WRONG_ARGUMENTS);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state)  == SERVICE_NO_ERROR);
			REQUIRE(BAPI.header(hea, q_state) == SERVICE_NO_ERROR);

			REQUIRE(memcmp(&hea, p_txn->p_block, sizeof(StaticBlockHeader)) == 0);

			p_txn->p_owner->destroy_transaction(p_txn);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3:input", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state)  == SERVICE_NO_ERROR);
			REQUIRE(BAPI.header(hea, q_state) == SERVICE_NO_ERROR);

			REQUIRE(memcmp(&hea, p_txn->p_block, sizeof(StaticBlockHeader)) == 0);

			p_txn->p_owner->destroy_transaction(p_txn);
			REQUIRE(p_txn == nullptr);

			REQUIRE(BAPI.parse(q_state, (pChar) "//no_lmdb/tt3bapi/bl3", BASE_API_GET));
			REQUIRE(BAPI.header(hea, q_state) == SERVICE_ERROR_WRONG_BASE);

			REQUIRE(BAPI.parse(q_state, (pChar) "///www//no_lmdb/tt3bapi/bl3", BASE_API_GET));
			REQUIRE(BAPI.header(hea, q_state) != SERVICE_NO_ERROR);
		}

		WHEN("We test get()") {

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/kaka_db/bl1=&[[1,0],[0,1]];", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) != SERVICE_NO_ERROR);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/tt3bapi.new", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/tt3bapi/key.attribute(1)", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//no_base/tt3bapi/key.attribute(1)=&text/html;", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_ERROR_WRONG_BASE);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3.attribute(1)=&text/html;", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl99.attribute(1)=&text/html;", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_ERROR_BLOCK_NOT_FOUND);
			REQUIRE(p_txn == nullptr);

			p_txn = (pTransaction) &q_state;
			REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_GET));
			q_state.apply = APPLY_JAZZ_INFO;
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_ERROR_WRONG_ARGUMENTS);
			REQUIRE(p_txn == nullptr);
		}

		WHEN("We test put()") {
			REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi/bl3", BASE_API_GET));
			REQUIRE(BAPI.get(p_txn, q_state) == SERVICE_NO_ERROR);
			REQUIRE(p_txn->p_block->cell_type == CELL_TYPE_TUPLE_ITEM);

			REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_PUT));
			q_state.apply = APPLY_JAZZ_INFO;
			REQUIRE(BAPI.put(q_state, p_txn->p_block) == SERVICE_ERROR_WRONG_ARGUMENTS);

			p_txn->p_owner->destroy_transaction(p_txn);
			REQUIRE(p_txn == nullptr);
		}

		WHEN("We test remove()") {
			REQUIRE(BAPI.parse(q_state, (pChar) "//base/entity/key", BASE_API_DELETE));
			q_state.apply = APPLY_JAZZ_INFO;
			REQUIRE(BAPI.remove(q_state) == SERVICE_ERROR_WRONG_ARGUMENTS);
		}

		REQUIRE(BAPI.parse(q_state, (pChar) "//lmdb/tt3bapi", BASE_API_DELETE));
		REQUIRE(BAPI.remove(q_state) == SERVICE_NO_ERROR);
	}

	REQUIRE(BAPI.shut_down() == 0);

	REQUIRE(CHN.shut_down() == 0);
	REQUIRE(VOL.shut_down() == 0);
	REQUIRE(PER.shut_down() == 0);
}


SCENARIO("Testing BaseAPI struct sizes and positions") {

	REQUIRE(sizeof(ApiQueryState) == 2048);

	ApiQueryState q_state;
	Locator loc;

	strcpy(q_state.base,   "base");
	strcpy(q_state.entity, "entity");
	strcpy(q_state.key,	   "abcdefghij0123456789ABCDEFGHIJ-");

	REQUIRE(strlen(q_state.key) == sizeof(q_state.key) - 1);

	memcpy(&loc, &q_state.base, SIZE_OF_BASE_ENT_KEY);

	REQUIRE(strcmp(loc.base,   "base") == 0);
	REQUIRE(strcmp(loc.entity, "entity") == 0);
	REQUIRE(strcmp(loc.key,	   "abcdefghij0123456789ABCDEFGHIJ-") == 0);
}
