// This is a double inclusion! It is required for VSCode' Intellisense to work properly. This file is itself included in the
// .cpp file of the same name for unit testing. It has no effect on compilation.
#pragma once
#include "src/jazz_bebop/base_api.h"


using namespace jazz_bebop;


SCENARIO("Testing all Containers start()/shut_down()aat BaseAPI level") {

	GIVEN("The instances are constructed, but not yet started") {
		REQUIRE(BAPI.p_channels	 == &CHN);
		REQUIRE(BAPI.p_volatile	 == &VOL);
		REQUIRE(BAPI.p_persisted == &PER);
	}

	REQUIRE(CHN.start()	== 0);
	REQUIRE(VOL.start()	== 0);
	REQUIRE(PER.start() == 0);

	REQUIRE(BAPI.start() == 0);

	GIVEN("The instances are started") {
		REQUIRE(BAPI.base_server[TenBitsAtAddress("bash")]	  == &CHN);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("file")]	  == &CHN);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("http")]	  == &CHN);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("0-mq")]	  == &CHN);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("deque")]	  == &VOL);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("index")]	  == &VOL);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("queue")]	  == &VOL);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("tree")]	  == &VOL);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("lmdb")]	  == &PER);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("compile")] == nullptr);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("resolve")] == nullptr);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("bop")]	  == nullptr);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("brane")]	  == nullptr);
		REQUIRE(BAPI.base_server[TenBitsAtAddress("zqt")]	  == nullptr);
	}

	REQUIRE(BAPI.shut_down() == 0);

	REQUIRE(CHN.shut_down() == 0);
	REQUIRE(VOL.shut_down() == 0);
	REQUIRE(PER.shut_down() == 0);
}


SCENARIO("Testing BaseAPI.parse") {
	REQUIRE(BAPI.start() == 0);

	GIVEN("We want to test parse_locator()") {
		Locator	loc;

		loc.base[0]	  = 0xba;
		loc.entity[0] = 0xca;
		loc.key[0]	  = 0xda;
		loc.p_extra	  = (pExtraLocator) &loc;

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base/entity/key"));

		REQUIRE(strcmp(loc.base,   "base")	 == 0);
		REQUIRE(strcmp(loc.entity, "entity") == 0);
		REQUIRE(strcmp(loc.key,	   "key")	 == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base-_1/abcdefghij01234567890123456789~/ABCDEFGHIJ_1234567890abcdefghij)"));

		REQUIRE(strcmp(loc.base,   "base-_1") == 0);
		REQUIRE(strcmp(loc.entity, "abcdefghij01234567890123456789~") == 0);
		REQUIRE(strcmp(loc.key,	   "ABCDEFGHIJ_1234567890abcdefghij") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(strlen(loc.base)   == sizeof(loc.base) - 1);
		REQUIRE(strlen(loc.entity) == sizeof(loc.entity) - 1);
		REQUIRE(strlen(loc.key)	   == sizeof(loc.key) - 1);

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//base-_12/abcdefghij01234567890123456789~/ABCDEFGHIJ_1234567890abcdefghij"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//base-_1/abcdefghij01234567890123456789~2/ABCDEFGHIJ_1234567890abcdefghij"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//base-_1/abcdefghij01234567890123456789~/ABCDEFGHIJ_1234567890abcdefghij2"));

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//ase-_10/bcdefghij01234567890123456789~0/ABCDEFGHIJ_0123456789abcdefghij"));
		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base1/azAZ_-~09/AZaz_-~09]"));

		REQUIRE(strcmp(loc.base,   "base1") == 0);
		REQUIRE(strcmp(loc.entity, "azAZ_-~09") == 0);
		REQUIRE(strcmp(loc.key,	   "AZaz_-~09") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base2/azAZ_-~08/AZaz_-~08)"));

		REQUIRE(strcmp(loc.base,   "base2") == 0);
		REQUIRE(strcmp(loc.entity, "azAZ_-~08") == 0);
		REQUIRE(strcmp(loc.key,	   "AZaz_-~08") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base2b/azAZ_-~10)"));

		REQUIRE(strcmp(loc.base,   "base2b") == 0);
		REQUIRE(strcmp(loc.entity, "azAZ_-~10") == 0);
		REQUIRE(loc.key[0] == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//base3/azAZ_-~07/AZaz_-~07"));

		REQUIRE(strcmp(loc.base,   "base3") == 0);
		REQUIRE(strcmp(loc.entity, "azAZ_-~07") == 0);
		REQUIRE(strcmp(loc.key,	   "AZaz_-~07") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//base/azAZ_-~09/AZaz_-~09("));

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//base/azAZ_-~09/AZaz_-~09]]"));

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//bas e/azAZ_-~09/AZaz_-~09"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//ba'se/azAZ_-~09/AZaz_-~09"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//ba/se/azAZ_-~09/AZaz_-~09"));

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//b/e/k"));

		REQUIRE(strcmp(loc.base,   "b") == 0);
		REQUIRE(strcmp(loc.entity, "e") == 0);
		REQUIRE(strcmp(loc.key,	   "k") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//0/e/k"));

		REQUIRE(strcmp(loc.base,   "0") == 0);
		REQUIRE(strcmp(loc.entity, "e") == 0);
		REQUIRE(strcmp(loc.key,	   "k") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//b/0/k"));

		REQUIRE(strcmp(loc.base,   "b") == 0);
		REQUIRE(strcmp(loc.entity, "0") == 0);
		REQUIRE(strcmp(loc.key,	   "k") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//b/e/0"));

		REQUIRE(strcmp(loc.base,   "b") == 0);
		REQUIRE(strcmp(loc.entity, "e") == 0);
		REQUIRE(strcmp(loc.key,	   "0") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//-/e/k"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//b/-/k"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//b/e/-"));

		REQUIRE(!BAPI.parse_locator(loc, (pChar) "/b/e/k"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//b"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//b/e/"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//b/e/k/"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "///b/e/k"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "///n//b/e/k"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "//"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "/"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) "a"));
		REQUIRE(!BAPI.parse_locator(loc, (pChar) ""));

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//deque/entity/~pop_first"));

		REQUIRE(strcmp(loc.base,   "deque") == 0);
		REQUIRE(strcmp(loc.entity, "entity") == 0);
		REQUIRE(strcmp(loc.key,	   "~pop_first") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//deque/entity/key~prev"));

		REQUIRE(strcmp(loc.base,   "deque") == 0);
		REQUIRE(strcmp(loc.entity, "entity") == 0);
		REQUIRE(strcmp(loc.key,	   "key~prev") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//index/id/~si"));

		REQUIRE(strcmp(loc.base,   "index") == 0);
		REQUIRE(strcmp(loc.entity, "id") == 0);
		REQUIRE(strcmp(loc.key,	   "~si") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//queue/candidates/~5000"));

		REQUIRE(strcmp(loc.base,   "queue") == 0);
		REQUIRE(strcmp(loc.entity, "candidates") == 0);
		REQUIRE(strcmp(loc.key,	   "~5000") == 0);
		REQUIRE(loc.p_extra == nullptr);

		REQUIRE(BAPI.parse_locator(loc, (pChar) "//tree/game/node0a7ef~node0244e"));

		REQUIRE(strcmp(loc.base,   "tree") == 0);
		REQUIRE(strcmp(loc.entity, "game") == 0);
		REQUIRE(strcmp(loc.key,	   "node0a7ef~node0244e") == 0);
		REQUIRE(loc.p_extra == nullptr);
	}

	GIVEN("We want to test parse()") {
		ApiQueryState hqs;

		hqs.l_node[0] = 'a';
		hqs.r_node[0] = 'b';
		hqs.url[0]	  = 'z';

		REQUIRE(BAPI.parse(hqs, (pChar) "///", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_JAZZ_INFO);

		REQUIRE(hqs.l_node[0] == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(hqs.url[0]	  == 0);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///abcdefghijABCDEFGHIJ0123456789_//bb/ee/kk:nn", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "abcdefghijABCDEFGHIJ0123456789_") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "bb") == 0);
		REQUIRE(strcmp(hqs.entity, "ee") == 0);
		REQUIRE(strcmp(hqs.key,	   "kk") == 0);
		REQUIRE(strcmp(hqs.name,   "nn") == 0);
		REQUIRE(strcmp(hqs.url,	   "//bb/ee/kk:nn") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///abcdefghijABCDEFGHIJ0123456789_//bb/ee/kk:nn", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///abcdefghijABCDEFGHIJ0123456789_0//bb/ee/kk:nn", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///node//abc1234/ee/kk:nn", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "abc1234") == 0);
		REQUIRE(strcmp(hqs.entity, "ee") == 0);
		REQUIRE(strcmp(hqs.key,	   "kk") == 0);
		REQUIRE(strcmp(hqs.name,   "nn") == 0);
		REQUIRE(strcmp(hqs.url,	   "//abc1234/ee/kk:nn") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///no de//abc1234/ee/kk:nn", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "//abc1234/ee/kk)", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//abc12345/ee/kk:nn", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///node//base/abcdefghijABCDEFGHIJ0123456789_/kk:nn", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "abcdefghijABCDEFGHIJ0123456789_") == 0);
		REQUIRE(strcmp(hqs.key,	   "kk") == 0);
		REQUIRE(strcmp(hqs.name,   "nn") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base/abcdefghijABCDEFGHIJ0123456789_/kk:nn") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base/abcdefghijABCDEFGHIJ0123456789_7/kk:nn", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///node//base/entity/ABCDEFGHIJ0123456789abcdefghijk:nn", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "ABCDEFGHIJ0123456789abcdefghijk") == 0);
		REQUIRE(strcmp(hqs.name,   "nn") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base/entity/ABCDEFGHIJ0123456789abcdefghijk:nn") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base/entity/ABCDEFGHIJ0123456789abcdefghijkl:nn", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///node//base/entity/key:n123456789ABCDEFGHIJK0123456789", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "key") == 0);
		REQUIRE(strcmp(hqs.name,   "n123456789ABCDEFGHIJK0123456789") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base/entity/key:n123456789ABCDEFGHIJK0123456789") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///node//base/entity/key:n123456789ABCDEFGHIJK01234567890", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///r_node//base/entity/r_key", BASE_API_GET));

		REQUIRE(strcmp(hqs.l_node, "r_node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "r_key") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base/entity/r_key") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);

		REQUIRE(BAPI.parse(hqs, (pChar) "///w_node//base/entity/w_key", BASE_API_PUT));

		REQUIRE(strcmp(hqs.l_node, "w_node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "w_key") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base/entity/w_key") == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///r_node//base_x/entity", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_x/entity", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///w_node//base_y/entity", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "///w_node//base_y/entity", BASE_API_DELETE));

		REQUIRE(strcmp(hqs.l_node, "w_node") == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base_y") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.url,	   "//base_y/entity") == 0);

		REQUIRE(hqs.key[0] == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);

		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_y/entity", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "//base_y/entity", BASE_API_DELETE));

		REQUIRE(hqs.l_node[0] == 0);
		REQUIRE(hqs.r_node[0] == 0);
		REQUIRE(strcmp(hqs.base,   "base_y") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(hqs.url[0] == 0);
		REQUIRE(hqs.key[0] == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///r_node//base_x/entity/", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///w_node//base_y/entity/", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///r_node//base_x/", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///w_node//base_y/", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///r_node//base_x", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "///w_node//base_y", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "//base/entity/key:n123456789ABCDEFGHIJK0123456789", BASE_API_GET));

		REQUIRE(hqs.l_node[0] == 0);
		REQUIRE(hqs.r_node[0] == 0);

		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "key") == 0);
		REQUIRE(strcmp(hqs.name,   "n123456789ABCDEFGHIJK0123456789") == 0);
		REQUIRE(hqs.url[0] == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NAME);

		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_y/entity", BASE_API_GET));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(!BAPI.parse(hqs, (pChar) "//base_y/entity", BASE_API_PUT));

		REQUIRE(hqs.state == PSTATE_FAILED);

		REQUIRE(BAPI.parse(hqs, (pChar) "//base_y/entity", BASE_API_DELETE));

		REQUIRE(hqs.l_node[0] == 0);
		REQUIRE(hqs.r_node[0] == 0);

		REQUIRE(strcmp(hqs.base,   "base_y") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(hqs.url[0] == 0);

		REQUIRE(hqs.key[0] == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);

		REQUIRE(BAPI.parse(hqs, (pChar) "//base/entity/key.raw", BASE_API_GET));

		REQUIRE(hqs.l_node[0] == 0);
		REQUIRE(hqs.r_node[0] == 0);

		REQUIRE(strcmp(hqs.base,   "base") == 0);
		REQUIRE(strcmp(hqs.entity, "entity") == 0);
		REQUIRE(strcmp(hqs.key,	   "key") == 0);
		REQUIRE(hqs.url[0] == 0);

