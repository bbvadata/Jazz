		REQUIRE(hqs.url[0] == 0);

		REQUIRE(hqs.state == PSTATE_COMPLETE_OK);
		REQUIRE(hqs.apply == APPLY_NOTHING);
	}

	GIVEN("We test parse() for PUT and DELETE") {
		ApiQueryState hqs;

		hqs.l_node[0] = 'a';
		hqs.r_node[0] = 'b';
		hqs.url[0]	  = 'z';

